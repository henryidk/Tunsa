@startuml D3_CU12_Baja_Equipo
title CU-12 — Dar de Baja Equipo

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Administrador" as Admin
actor "Secretaria"    as Sec

rectangle "Sistema Tunsa — Equipos" {
  usecase "CU-12\nDar de Baja\nEquipo" as CU12

  usecase "Ingresar motivo\nde baja"              as Motivo
  usecase "Registrar fechaBaja\ny motivoBaja"     as RegistrarBaja
  usecase "Registrar cambio\nen Bitácora"         as Bitacora
}

Admin --> CU12
Sec   --> CU12

CU12 .right.> Motivo       : <<include>>
CU12 .right.> RegistrarBaja : <<include>>
CU12 .right.> Bitacora     : <<include>>

@enduml
