@startuml D4_CU24_Bitacora
title CU-24 — Consultar Bitácora de Cambios

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Administrador" as Admin

rectangle "Sistema Tunsa — Bitácora" {
  usecase "CU-24\nConsultar Bitácora\nde Cambios" as CU24

  usecase "Ver estadísticas:\ntotal, hoy, equipos,\nusuarios"       as Stats
  usecase "Ver tabla:\nfecha, módulo, entidad,\ncampo, antes/después" as Tabla
  usecase "Filtrar por módulo\ny búsqueda"                            as Filtrar
}

Admin --> CU24

CU24 .right.> Stats   : <<include>>
CU24 .right.> Tabla   : <<include>>
CU24 .right.> Filtrar : <<extend>>\n[opcional]

note bottom of CU24
  Solo lectura.
  No modifica ningún registro.
end note

@enduml
