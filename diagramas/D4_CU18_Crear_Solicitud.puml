@startuml D4_CU18_Crear_Solicitud
title CU-18 — Crear Solicitud de Renta

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Encargado de Máquinas" as Enc

rectangle "Sistema Tunsa — Solicitudes de Renta" {
  usecase "CU-18\nCrear Solicitud\nde Renta"       as CU18

  usecase "Seleccionar cliente\nregistrado"         as SelCliente
  usecase "Agregar equipos\ncon período de renta"   as AgregarEquipos
  usecase "Calcular total\nestimado"                as CalcTotal
  usecase "Registrar solicitud\nestado: Pendiente"  as RegSolicitud
}

Enc --> CU18

CU18 .right.> SelCliente   : <<include>>
CU18 .right.> AgregarEquipos : <<include>>
CU18 .right.> CalcTotal    : <<include>>
CU18 .right.> RegSolicitud : <<include>>

note bottom of CU18
  La solicitud queda en estado
  Pendiente hasta ser aprobada
  o rechazada por Admin/Secretaria
end note

@enduml
