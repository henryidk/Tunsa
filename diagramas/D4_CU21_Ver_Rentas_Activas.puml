@startuml D4_CU21_Ver_Rentas_Activas
title CU-21 — Ver Rentas Activas

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Administrador" as Admin
actor "Secretaria"    as Sec
actor "Colaborador"   as Col

rectangle "Sistema Tunsa — Rentas Activas" {
  usecase "CU-21\nVer Rentas\nActivas" as CU21

  usecase "Ver resumen:\ncontratos, equipos,\ningresos proyectados" as Resumen
  usecase "Ver tabla de\ncontratos activos"                         as Tabla
  usecase "Ver detalle\nde contrato\n(RentaModal)"                  as Detalle
}

Admin --> CU21
Sec   --> CU21
Col   --> CU21

CU21 .right.> Resumen : <<include>>
CU21 .right.> Tabla   : <<include>>
Tabla .right.> Detalle : <<extend>>\n[clic en "Ver detalle"]

@enduml
