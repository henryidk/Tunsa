@startuml D3_CU09_Agregar_Equipo
title CU-09 — Agregar Equipo al Inventario

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Administrador"          as Admin
actor "Secretaria"             as Sec
actor "Encargado de Máquinas"  as Enc

rectangle "Sistema Tunsa — Equipos" {
  usecase "CU-09\nAgregar Equipo\nal Inventario" as CU09

  usecase "Validar numeración\núnica"            as ValNum
  usecase "Registrar precios\nde renta opcionales" as Precios
}

Admin --> CU09
Sec   --> CU09
Enc   --> CU09

CU09 .right.> ValNum   : <<include>>
CU09 .right.> Precios  : <<extend>>\n[si se ingresan precios]

@enduml
