// Archivo de schema de Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTENTICACIÓN ====================

model Usuario {
  id            String   @id @default(cuid())
  username      String   @unique  // Usuario único (ej: "admin", "secretaria1")
  password      String              // Hash bcrypt (NO la contraseña real)
  nombre        String              // Nombre completo
  telefono      String?             // Teléfono opcional
  isActive            Boolean  @default(true)
  mustChangePassword  Boolean  @default(false)

  roleId        String
  role          Role     @relation(fields: [roleId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relaciones
  refreshTokens RefreshToken[]
  
  @@map("usuarios")
  @@index([username])
}

model Role {
  id          String   @id @default(cuid())
  nombre      String   @unique  // admin, secretaria, colaborador, encargado_maquinas
  descripcion String?
  
  createdAt   DateTime @default(now())
  
  usuarios    Usuario[]
  
  @@map("roles")
}

model RefreshToken {
  id            String    @id @default(cuid())
  token         String    @db.Text
  
  userId        String
  user          Usuario   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  expiresAt     DateTime
  revoked       Boolean   @default(false)
  revokedAt     DateTime?
  
  // Información de seguridad
  device        String?   // Navegador/dispositivo
  ipAddress     String?   // IP desde donde se conectó
  userAgent     String?   @db.Text
  
  createdAt     DateTime  @default(now())
  
  @@map("refresh_tokens")
  @@index([userId])
  @@index([revoked, expiresAt])
}

// ==================== EQUIPOS ====================

enum TipoMaquinaria {
  LIVIANA
  PESADA
  USO_PROPIO
}

model Equipo {
  id           String         @id @default(cuid())
  numeracion   String         @unique          // Código interno: "1", "47", "MP01", "PT01"
  descripcion  String         @db.Text
  categoria    String                          // "Bailarina", "Generador", "Puntales", etc.
  serie        String?        @db.Text         // Serie equipo / motor
  cantidad     Int            @default(1)      // Unidades (>1 para materiales a granel como puntales)
  fechaCompra  DateTime
  montoCompra  Decimal        @db.Decimal(12, 2) // Valor total del lote
  tipo         TipoMaquinaria @default(LIVIANA)

  rentaDia     Decimal?       @db.Decimal(10, 2)
  rentaSemana  Decimal?       @db.Decimal(10, 2)
  rentaMes     Decimal?       @db.Decimal(10, 2)

  isActive     Boolean        @default(true)
  motivoBaja   String?
  fechaBaja    DateTime?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("equipos")
  @@index([categoria])
  @@index([tipo])
  @@index([isActive])
}

// ==================== BITÁCORAS ====================

model Bitacora {
  id            String   @id @default(cuid())
  modulo        String   // "equipo" | "usuario"
  entidadId     String
  entidadNombre String
  campo         String
  valorAnterior String?
  valorNuevo    String?
  realizadoPor  String

  createdAt     DateTime @default(now())

  @@map("bitacoras")
  @@index([modulo, createdAt])
  @@index([entidadId])
}

// ==================== CATEGORÍAS ====================

model Categoria {
  id        String   @id @default(cuid())
  nombre    String   @unique
  createdAt DateTime @default(now())

  @@map("categorias")
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id         String   @id @default(cuid())
  
  userId     String?  // Null si es intento fallido
  username   String?  // Para intentos fallidos
  
  action     String   // LOGIN_SUCCESS, LOGIN_FAILED, LOGOUT, etc.
  
  ipAddress  String?
  userAgent  String?  @db.Text
  
  details    Json?    // Información adicional
  
  createdAt  DateTime @default(now())
  
  @@map("audit_logs")
  @@index([username, createdAt])
  @@index([action, createdAt])
}
