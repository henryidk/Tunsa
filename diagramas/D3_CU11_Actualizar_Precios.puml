@startuml D3_CU11_Actualizar_Precios
title CU-11 — Actualizar Precios de Renta de Equipo

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Administrador" as Admin
actor "Secretaria"    as Sec

rectangle "Sistema Tunsa — Equipos" {
  usecase "CU-11\nActualizar Precios\nde Renta" as CU11

  usecase "Registrar cambio\nen Bitácora"       as Bitacora
  usecase "Validar precios\nno negativos"        as ValPrecios
}

Admin --> CU11
Sec   --> CU11

CU11 .right.> ValPrecios : <<include>>
CU11 .right.> Bitacora   : <<include>>\n[por cada precio modificado]

@enduml
