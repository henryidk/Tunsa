@startuml D4_CU23_Historial_Rentas
title CU-23 — Consultar Historial de Rentas

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Administrador"          as Admin
actor "Secretaria"             as Sec
actor "Encargado de Máquinas"  as Enc

rectangle "Sistema Tunsa — Historial de Rentas" {
  usecase "CU-23\nConsultar Historial\nde Rentas" as CU23

  usecase "Filtrar por estado,\nfecha y búsqueda"  as Filtrar
}

Admin --> CU23
Sec   --> CU23
Enc   --> CU23

CU23 .right.> Filtrar : <<extend>>\n[opcional]

@enduml
