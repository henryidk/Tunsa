// Archivo de schema de Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTENTICACIÓN ====================

model Usuario {
  id            String   @id @default(cuid())
  username      String   @unique  // Usuario único (ej: "admin", "secretaria1")
  password      String              // Hash bcrypt (NO la contraseña real)
  nombre        String              // Nombre completo
  telefono      String?             // Teléfono opcional
  isActive            Boolean  @default(true)
  mustChangePassword  Boolean  @default(false)

  roleId        String
  role          Role     @relation(fields: [roleId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relaciones
  refreshTokens RefreshToken[]

  @@map("usuarios")
  // @@index([username]) eliminado: @unique ya crea un índice, este era redundante
}

model Role {
  id          String   @id @default(cuid())
  nombre      String   @unique  // admin, secretaria, encargado_maquinas
  descripcion String?
  
  createdAt   DateTime @default(now())
  
  usuarios    Usuario[]
  
  @@map("roles")
}

model RefreshToken {
  id            String    @id @default(cuid())
  token         String    @unique @db.Text  // @unique: O(1) lookup en revocación y validación
  
  userId        String
  user          Usuario   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  expiresAt     DateTime
  revoked       Boolean   @default(false)
  revokedAt     DateTime?
  
  // Información de seguridad
  device        String?   // Navegador/dispositivo
  ipAddress     String?   // IP desde donde se conectó
  userAgent     String?   @db.Text
  
  createdAt     DateTime  @default(now())
  
  @@map("refresh_tokens")
  @@index([userId])
  @@index([revoked, expiresAt])
}

// ==================== EQUIPOS ====================

// Tipo de maquinaria: dato "padre". Categoría es hija de tipo.
model TipoEquipo {
  id          String      @id @default(cuid())
  nombre      String      @unique   // "LIVIANA" | "PESADA" | "USO_PROPIO"
  descripcion String?

  createdAt   DateTime    @default(now())

  categorias  Categoria[]
  equipos     Equipo[]

  @@map("tipos_equipo")
}

// Categoría pertenece a un TipoEquipo.
// @@unique([id, tipoId]) habilita la FK compuesta en equipos (integridad entre categoria y tipo).
model Categoria {
  id        String     @id @default(cuid())
  nombre    String
  tipoId    String     @map("tipo_id")
  tipo      TipoEquipo @relation(fields: [tipoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime   @default(now())

  equipos   Equipo[]

  @@unique([nombre, tipoId])  // nombre único dentro de cada tipo
  @@unique([id, tipoId])      // para FK compuesta desde equipos
  @@index([tipoId])
  @@map("categorias")
}

model Equipo {
  id           String     @id @default(cuid())
  numeracion   String     @unique
  descripcion  String     @db.Text
  serie        String?    @db.Text
  fechaCompra  DateTime
  montoCompra  Decimal    @db.Decimal(12, 2)

  // Tipo: requerido. Categoría: opcional, pero cuando existe debe pertenecer al mismo tipo.
  // La consistencia (categoria.tipoId == equipo.tipoId) se refuerza en DB con FK compuesta
  // y a nivel de servicio antes de persistir.
  tipoId      String     @map("tipo_id")
  tipo        TipoEquipo @relation(fields: [tipoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  categoriaId String?    @map("categoria_id")
  categoria   Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  rentaHora         Decimal?   @db.Decimal(10, 2)  // Exclusivo de PESADA
  rentaHoraMartillo Decimal?   @db.Decimal(10, 2)  // Exclusivo de retroexcavadoras (PESADA con martillo)
  rentaDia          Decimal?   @db.Decimal(10, 2)
  rentaSemana       Decimal?   @db.Decimal(10, 2)
  rentaMes          Decimal?   @db.Decimal(10, 2)

  isActive     Boolean    @default(true)
  motivoBaja   String?
  fechaBaja    DateTime?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  lecturas      LecturaHorometro[]

  @@map("equipos")
  @@index([tipoId])
  @@index([categoriaId])
  @@index([isActive, createdAt])
}

// ==================== SOLICITUDES DE RENTA ====================

enum ModalidadPago {
  CONTADO
  CREDITO
}

enum EstadoSolicitud {
  PENDIENTE
  APROBADA
  RECHAZADA
  ACTIVA     // entregada al cliente y firmada — renta en curso
  DEVUELTA   // cliente devolvió el equipo — renta cerrada
}

model Solicitud {
  id            String          @id @default(cuid())
  clienteId     String
  cliente       Cliente         @relation(fields: [clienteId], references: [id])
  items         Json
  modalidad     ModalidadPago
  notas         String          @db.Text
  totalEstimado Decimal         @db.Decimal(12, 2)
  estado        EstadoSolicitud @default(PENDIENTE)
  motivoRechazo String?         @db.Text
  creadaPor     String          // username del encargado

  // Folio — asignado al aprobar, nunca al crear
  folio         String?         @unique   // "202604-0001" — identifica la renta en documentos

  // Aprobación / rechazo
  aprobadaPor   String?         // username de quien aprobó
  fechaDecision DateTime?       // momento exacto en que admin aprobó o rechazó (inmutable)

  // Entrega y comprobante
  comprobanteKey   String?   // clave del objeto en R2: "clientes/CLI-XXXX/comprobantes/FOLIO.pdf"
  fechaInicioRenta DateTime? // momento exacto del primer "Generar Comprobante" — inicio oficial de la renta
  fechaEntrega     DateTime? // momento exacto en que se subió el comprobante firmado

  // Vencimiento y devolución
  fechaFinEstimada DateTime? // vencimiento más temprano entre todos los ítems (calculado al confirmar entrega)
  fechaDevolucion  DateTime? // momento en que el cliente entregó los equipos
  recargoTotal     Decimal?  @db.Decimal(12, 2) // cargo extra por días de atraso (0 si dentro de gracia)

  // Extensiones de renta — se acumulan sin mutar el JSON original de `items`.
  // Cada entrada identifica un ítem (por equipoId o tipo granel), la duración adicional y su costo adaptativo.
  extensiones           Json?     // ExtensionEntry[]

  // Devoluciones — puede haber múltiples entradas si la devolución es parcial.
  // Cada entrada registra qué ítems se devolvieron, cuándo, quién lo registró,
  // los cargos adicionales y la key del PDF de liquidación en R2.
  devolucionesParciales Json?     // DevolucionEntry[]

  // Flag: true cuando todos los ítems son PESADA (cobro por horómetro, sin totalEstimado real).
  esPesada              Boolean   @default(false)

  // Monto real cobrado al cerrar la renta (suma de todos los totalLote de devolucionesParciales).
  // Puede diferir de totalEstimado en devoluciones anticipadas o por recargos adicionales.
  totalFinal            Decimal?  @db.Decimal(12, 2)

  // Fecha de la última devolución registrada (parcial o completa).
  // Se actualiza en cada llamada a registrarDevolucion. Permite filtrar el historial
  // por fecha de devolución sin hacer queries sobre el JSONB devolucionesParciales.
  fechaUltimaDevolucion DateTime?

  lecturas              LecturaHorometro[]
  resumenItems          ResumenItem[]

  // Suma acumulada de costoTotal de todas las lecturas de horómetro.
  // Se incrementa atómicamente con cada lectura registrada o actualizada.
  costoAcumuladoPesada  Decimal   @default(0) @db.Decimal(12, 2)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("solicitudes")
  @@index([estado, createdAt])
  @@index([estado, fechaDecision, id])                          // keyset pagination admin: rechazadas
  @@index([creadaPor, estado, fechaDecision, id])               // keyset pagination encargado: historial-mias (rechazadas)
  @@index([creadaPor, fechaUltimaDevolucion, id])               // keyset pagination encargado: historial devueltas
  @@index([creadaPor, estado, fechaFinEstimada])                // consulta encargado: activas-mias y vencidas-mias
  @@index([clienteId])
}

// Contador mensual de folios — garantiza secuencia atómica sin gaps por mes.
// Una fila por mes (ej: "202604"). El campo `ultimo` es el último número asignado.
model FolioSecuencia {
  mesAnio String @id         // "202604"
  ultimo  Int    @default(0)

  @@map("folio_secuencias")
}

// ==================== INVENTARIO A GRANEL ====================
// Instrumentos rentados por cantidad sin distinción individual de IDs.
// Cada TipoGranel tiene su propio historial de lotes y su propia configuración de precios.

enum TipoGranel {
  PUNTAL
  ANDAMIO_SIMPLE
  ANDAMIO_RUEDAS
}

model LoteGranel {
  id             String     @id @default(cuid())
  tipo           TipoGranel
  descripcion    String
  cantidad       Int
  precioUnitario Decimal    @db.Decimal(10, 2)
  fechaCompra    DateTime?
  ubicacion      String?
  isActive       Boolean    @default(true)

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("lotes_granel")
  @@index([tipo, isActive])
}

// Un registro de precios por cada TipoGranel — la clave primaria es el tipo.
// Los campos *ConMadera son exclusivos de ANDAMIO_SIMPLE (nullable en los demás tipos).
model ConfigGranel {
  tipo                 TipoGranel @id
  rentaDia             Decimal    @db.Decimal(10, 2)
  rentaSemana          Decimal    @db.Decimal(10, 2)
  rentaMes             Decimal    @db.Decimal(10, 2)
  rentaDiaConMadera    Decimal?   @db.Decimal(10, 2)
  rentaSemanaConMadera Decimal?   @db.Decimal(10, 2)
  rentaMesConMadera    Decimal?   @db.Decimal(10, 2)
  updatedAt            DateTime   @updatedAt

  @@map("config_granel")
}

// ==================== BITÁCORAS ====================

model Bitacora {
  id            String   @id @default(cuid())
  modulo        String   // "equipo" | "usuario"
  entidadId     String
  entidadNombre String
  campo         String
  valorAnterior String?
  valorNuevo    String?
  realizadoPor  String

  createdAt     DateTime @default(now())

  @@map("bitacoras")
  @@index([createdAt, id])         // cursor pagination: ORDER BY createdAt DESC, id DESC — seek directo sin scan
  @@index([modulo, createdAt, id]) // filtro por módulo + cursor pagination
  @@index([entidadId])
}

// (Categoria definida arriba junto a TipoEquipo y Equipo)

// ==================== CLIENTES ====================

model Cliente {
  id           String   @id  // CLI-0001, CLI-0042 — auto-generado por el servicio
  nombre       String
  dpi          String   @unique
  telefono     String?  @unique
  documentoKey String?  // clave del objeto en R2: "clientes/CLI-0001/documento.pdf"
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  solicitudes  Solicitud[]

  @@map("clientes")
  @@index([nombre])
}

// ==================== HORÓMETRO (MAQUINARIA PESADA) ====================

/**
 * Registro diario de horómetro para maquinaria pesada en renta.
 * Una fila por (solicitud, equipo, fecha).
 *
 * Flujo de llenado:
 *  1. Mañana: se registra horometroInicio (crea la fila).
 *  2. 5 PM:   se registra horometroFin5pm; se calculan horasDiurnas y costos provisionales.
 *  3. Al registrar el horometroInicio del día siguiente:
 *     → si difiere de horometroFin5pm del día anterior, se actualiza horasNocturnas
 *       en la fila del día anterior y se recalculan sus costos definitivos.
 *  4. En la devolución: el horometroDevolucion cierra el último día igual que en (3).
 */
model LecturaHorometro {
  id            String    @id @default(cuid())
  solicitudId   String
  solicitud     Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  equipoId      String
  equipo        Equipo    @relation(fields: [equipoId], references: [id])

  fecha           DateTime  @db.Date    // Día al que pertenece la lectura

  horometroInicio Decimal?  @db.Decimal(10, 1)  // Lectura de inicio del día
  horometroFin5pm Decimal?  @db.Decimal(10, 1)  // Lectura a las 5 PM

  // Horas nocturnas de ESTE día — se conocen cuando se registra el inicio del día siguiente
  // (o en la devolución si es el último día).
  horasNocturnas  Decimal?  @db.Decimal(6, 1)

  // Calculados y persistidos al cerrar nocturnas (para evitar recalcular en cada consulta)
  horasDiurnasRaw        Decimal?  @db.Decimal(6, 1)   // horometroFin5pm − horometroInicio
  horasDiurnasFacturadas Decimal?  @db.Decimal(6, 1)   // horasDiurnasRaw + ajusteMinimo
  ajusteMinimo           Decimal?  @db.Decimal(6, 1)   // horas diurnas añadidas para llegar a 5 h/día
  tarifaEfectiva         Decimal?  @db.Decimal(10, 2)  // Q/hora aplicada (con o sin martillo)
  costoDiurno            Decimal?  @db.Decimal(10, 2)
  costoNocturno          Decimal?  @db.Decimal(10, 2)
  costoTotal             Decimal?  @db.Decimal(10, 2)

  registradoInicioBy  String?
  registradoFinBy     String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([solicitudId, equipoId, fecha])
  @@index([solicitudId, equipoId])
  @@map("lecturas_horometro")
}

// ==================== RESUMEN DE ÍTEMS (cierre de renta) ====================

/**
 * Registro de cierre por ítem — se crea al confirmar entrega y se completa al devolver.
 * Cubre todos los tipos: maquinaria liviana, granel y maquinaria pesada.
 * Para pesadas, DetalleHorometro extiende este registro con los campos de horómetro.
 */
model ResumenItem {
  id              String    @id @default(cuid())
  solicitudId     String
  clienteId       String                        // desnormalizado para queries de reporte
  equipoId        String?                       // null para granel
  itemRef         String                        // equipoId (maquinaria/pesada) o tipo (granel)
  tipoItem        String                        // 'maquinaria' | 'granel' | 'pesada'
  fechaEntrega    DateTime
  fechaDevolucion DateTime?
  tarifaEfectiva  Decimal   @db.Decimal(10,2)  // snapshot del precio aplicado
  diasCobrados    Int?                           // livianas/granel
  costoFinal      Decimal?  @db.Decimal(12,2)

  solicitud Solicitud         @relation(fields: [solicitudId], references: [id])
  horometro DetalleHorometro?

  @@unique([solicitudId, itemRef])
  @@index([clienteId])
  @@index([equipoId])
  @@map("resumen_items")
}

/**
 * Extensión de ResumenItem exclusiva para maquinaria pesada.
 * Se crea junto al ResumenItem (con horometroEntrega) y se completa en la devolución.
 */
model DetalleHorometro {
  resumenItemId       String   @id
  horometroEntrega    Decimal? @db.Decimal(10,1)  // lectura al iniciar la renta
  horometroDevolucion Decimal? @db.Decimal(10,1)  // lectura final al devolver
  horasDiurnasTotal   Decimal? @db.Decimal(10,1)  // Σ horasDiurnasFacturadas de todas las lecturas
  ajusteMinimoTotal   Decimal? @db.Decimal(10,1)  // Σ ajusteMinimo aplicado
  horasNocturnas      Decimal? @db.Decimal(10,1)  // total horas después de 5 PM

  resumenItem ResumenItem @relation(fields: [resumenItemId], references: [id])

  @@map("detalles_horometro")
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id         String   @id @default(cuid())
  
  userId     String?  // Null si es intento fallido
  username   String?  // Para intentos fallidos
  
  action     String   // LOGIN_SUCCESS, LOGIN_FAILED, LOGOUT, etc.
  
  ipAddress  String?
  userAgent  String?  @db.Text
  
  details    Json?    // Información adicional
  
  createdAt  DateTime @default(now())
  
  @@map("audit_logs")
  @@index([username, createdAt])
  @@index([action, createdAt])
  @@index([userId, createdAt])     // consultas por usuario específico ordenadas por fecha
}
