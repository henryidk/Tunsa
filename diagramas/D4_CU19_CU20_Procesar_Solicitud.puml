@startuml D4_CU19_CU20_Procesar_Solicitud
title CU-19 / CU-20 — Aprobar y Rechazar Solicitud de Renta

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Administrador" as Admin
actor "Secretaria"    as Sec

rectangle "Sistema Tunsa — Solicitudes de Renta" {
  usecase "Ver detalle\nde solicitud (RentaModal)" as VerDetalle

  usecase "CU-19\nAprobar Solicitud\nde Renta"  as CU19
  usecase "CU-20\nRechazar Solicitud\nde Renta" as CU20

  usecase "Marcar equipos\ncomo en renta"       as MarcarRenta
  usecase "Mover a\nRentas Activas"             as RentasActivas
  usecase "Registrar estado\nRechazada"         as RegRechazada
}

Admin --> VerDetalle
Sec   --> VerDetalle

VerDetalle .down.> CU19 : <<extend>>\n[actor aprueba]
VerDetalle .down.> CU20 : <<extend>>\n[actor rechaza]

CU19 .right.> MarcarRenta   : <<include>>
CU19 .right.> RentasActivas : <<include>>
CU20 .right.> RegRechazada  : <<include>>

@enduml
