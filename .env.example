# ============================================================
# Copiar este archivo como .env y completar los valores reales.
# NUNCA subir el archivo .env al repositorio.
# ============================================================

# PostgreSQL
POSTGRES_USER=ferre_tunsa
POSTGRES_PASSWORD=tu_password_seguro_aqui
POSTGRES_DB=ferreteria_db

# URL de conexión (codificar caracteres especiales del password en la URL)
DATABASE_URL=postgresql://ferre_tunsa:tu_password_aqui@postgres:5432/ferreteria_db?schema=public

# JWT — usar strings aleatorios de mínimo 48 caracteres
# Generar con: openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Servidor
PORT=4000
NODE_ENV=development

# CORS — URL del frontend
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend
VITE_API_URL=http://localhost:4000/api
