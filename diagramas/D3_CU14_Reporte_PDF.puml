@startuml D3_CU14_Reporte_PDF
title CU-14 — Generar Reporte PDF de Inventario

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Administrador"          as Admin
actor "Secretaria"             as Sec
actor "Encargado de Máquinas"  as Enc

rectangle "Sistema Tunsa — Equipos" {
  usecase "CU-14\nGenerar Reporte PDF\nde Inventario" as CU14

  usecase "Recopilar equipos\nde la base de datos"     as Recopilar
  usecase "Generar documento\nPDF A4 landscape"        as GenerarPDF
  usecase "Descargar archivo\ninventario_YYYY-MM-DD.pdf" as Descargar
}

Admin --> CU14
Sec   --> CU14
Enc   --> CU14

CU14 .right.> Recopilar  : <<include>>
CU14 .right.> GenerarPDF : <<include>>
CU14 .right.> Descargar  : <<include>>

@enduml
