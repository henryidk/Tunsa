@startuml D3_CU10_Editar_Equipo
title CU-10 — Editar Datos de Equipo

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Administrador"          as Admin
actor "Secretaria"             as Sec
actor "Encargado de Máquinas"  as Enc

rectangle "Sistema Tunsa — Equipos" {
  usecase "CU-10\nEditar Datos\nde Equipo" as CU10

  usecase "Registrar cambio\nen Bitácora"  as Bitacora
}

Admin --> CU10
Sec   --> CU10
Enc   --> CU10

CU10 .right.> Bitacora : <<include>>\n[por cada campo modificado]

note right of Bitacora
  Registra valor anterior
  y nuevo por cada campo
end note

@enduml
