@startuml D1_Autenticacion_Seguridad
title Módulo 1 — Autenticación y Seguridad\nCU-01 · CU-02 · CU-03

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3F51B5
  FontColor #1A1A2E
}
skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #5C6BC0
  FontColor #1A1A2E
  ArrowColor #5C6BC0
}

actor "Administrador"          as Admin
actor "Secretaria"             as Sec
actor "Colaborador"            as Col
actor "Encargado de Máquinas"  as Enc

rectangle "Sistema Tunsa — Autenticación y Seguridad" {
  usecase "CU-01\nIniciar Sesión"               as CU01
  usecase "CU-02\nCerrar Sesión"                as CU02
  usecase "CU-03\nCambiar Contraseña\n(Forzada)" as CU03

  usecase "Registrar evento\nen AuditLog"        as Audit
  usecase "Revocar\nRefresh Tokens"              as Revoke
}

Admin --> CU01
Admin --> CU02
Admin --> CU03
Sec   --> CU01
Sec   --> CU02
Sec   --> CU03
Col   --> CU01
Col   --> CU02
Col   --> CU03
Enc   --> CU01
Enc   --> CU02
Enc   --> CU03

CU01 .right.> Audit   : <<include>>
CU02 .right.> Revoke  : <<include>>
CU01 .down.>  CU03    : <<extend>>\n[mustChangePassword=true]

note bottom of CU03
  Se activa automáticamente
  tras CU-01 o CU-08
end note

@enduml
